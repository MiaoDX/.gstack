#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
MESSAGE="${1:-}"

cd "$ROOT"

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "sync-push: $ROOT is not a git repo. Run ./sync-init first." >&2
  exit 1
fi

if ! git remote get-url origin >/dev/null 2>&1; then
  echo "sync-push: origin is not set. Run ./sync-init <remote-url> first." >&2
  exit 1
fi

mkdir -p analytics sessions sidebar-sessions slug-cache worktrees projects
chmod 700 "$ROOT" analytics sessions sidebar-sessions slug-cache worktrees projects 2>/dev/null || true
[ -f config.yaml ] && chmod 600 config.yaml 2>/dev/null || true

BRANCH="$(git branch --show-current 2>/dev/null || echo main)"

if git rev-parse --verify "@{upstream}" >/dev/null 2>&1; then
  git pull --rebase --autostash
fi

git add -A

if ! git diff --cached --quiet; then
  if [ -z "$MESSAGE" ]; then
    HOST="$(hostname -s 2>/dev/null || hostname 2>/dev/null || echo unknown-host)"
    MESSAGE="chore: sync gstack state from $HOST"
  fi
  git commit -m "$MESSAGE"
fi

if git rev-parse --verify "@{upstream}" >/dev/null 2>&1; then
  git push
else
  git push -u origin "$BRANCH"
fi
